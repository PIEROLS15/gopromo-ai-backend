generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PaymentMethod {
  Cash
  Card
  Transfer
  Yape
  Plin
}

enum ReservationStatus {
  Pending
  Confirmed
  Cancelled
  Completed
}

enum PaymentStatus {
  Pending
  Paid
  Failed
  Refunded
}

model Role {
  /// Catálogo de roles del sistema (Admin, Supplier, User, etc.).
  id        Int        @id @default(autoincrement())
  name      String     @unique
  /// Usuarios finales asignados a este rol.
  users     User[]
  /// Proveedores asignados a este rol.
  suppliers Supplier[]
}

model User {
  /// Cuentas de usuarios finales que reservan paquetes turísticos.
  id                     Int      @id @default(autoincrement())
  email                  String   @unique
  fullName               String
  educationalInstitution String?
  phone                  String?
  password               String
  resetPasswordToken     String?
  avatar                 String?
  roleId                 Int
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  /// Reservas creadas por el usuario.
  reservations Reservation[]

  /// Rol funcional del usuario dentro del sistema.
  role Role @relation(fields: [roleId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([roleId])
  @@index([createdAt])
}

model Supplier {
  /// Cuentas de empresas proveedoras que publican paquetes y promociones.
  id                 Int      @id @default(autoincrement())
  email              String   @unique
  ruc                String   @unique
  representativeName String   @unique
  companyName        String   @unique
  phone              String
  password           String
  resetPasswordToken String?
  avatar             String?
  roleId             Int
  active             Boolean  @default(true)
  verified           Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  /// Paquetes turísticos publicados por el proveedor.
  tourPackages TourPackage[]
  /// Promociones creadas por el proveedor.
  promotions   Promotion[]

  /// Rol funcional del proveedor dentro del sistema.
  role Role @relation(fields: [roleId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([roleId])
  @@index([active, verified])
}

model TourPackage {
  /// Producto principal del negocio: paquete turístico ofertado por un proveedor.
  id                Int     @id @default(autoincrement())
  name              String  @unique
  districtId        Int
  pricePersona      Decimal @db.Decimal(10, 2)
  categoryPackageId Int
  educationLevelId  Int
  description       String
  days              Int     @default(1)
  minStudents       Int     @default(1)

  /// Galería de imágenes del paquete.
  images TourImage[]

  /// Días que conforman el itinerario del paquete.
  itineraryDays TourItineraryDay[]

  supplierId         Int
  promotions         Promotion[]
  active             Boolean             @default(false)
  offers             OfferTourPackage[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  reservationDetails ReservationDetail[]

  // Servicios
  travelInsurance Boolean @default(false)
  transport       Boolean @default(false)
  feeding         Boolean @default(false)
  lodging         Boolean @default(false)

  // Días de disponibilidad para reservaciones
  availableMonday    Boolean @default(false)
  availableTuesday   Boolean @default(false)
  availableWednesday Boolean @default(false)
  availableThursday  Boolean @default(false)
  availableFriday    Boolean @default(false)
  availableSaturday  Boolean @default(false)
  availableSunday    Boolean @default(false)

  categoryPackage CategoryPackage @relation(fields: [categoryPackageId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  educationLevel  EducationLevel  @relation(fields: [educationLevelId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  supplier        Supplier        @relation(fields: [supplierId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  district        District        @relation(fields: [districtId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([districtId])
  @@index([supplierId])
  @@index([categoryPackageId])
  @@index([educationLevelId])
  @@index([active])
}

model TourItineraryDay {
  /// Día de itinerario de un paquete (Día 1, Día 2, etc.).
  id            Int    @id @default(autoincrement())
  tourPackageId Int
  day           Int
  title         String

  steps       TourItineraryStep[]
  tourPackage TourPackage         @relation(fields: [tourPackageId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([tourPackageId, day])
}

model TourItineraryStep {
  /// Actividad puntual dentro de un día de itinerario.
  id          Int      @id @default(autoincrement())
  dayId       Int
  title       String
  hour        DateTime
  description String?
  order       Int

  day TourItineraryDay @relation(fields: [dayId], references: [id], onDelete: Cascade)

  @@unique([dayId, order])
}

model CategoryPackage {
  /// Catálogo de categorías de paquetes (aventura, cultural, etc.).
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tourPackages TourPackage[]
}

model EducationLevel {
  /// Catálogo de niveles educativos objetivo del paquete.
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tourPackages TourPackage[]
}

model TourImage {
  /// Imagen asociada a un paquete turístico.
  id            Int     @id @default(autoincrement())
  url           String
  tourPackageId Int
  isBanner      Boolean @default(false)
  order         Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tourPackage TourPackage @relation(fields: [tourPackageId], references: [id], onDelete: Cascade)

  @@index([tourPackageId])
}

model Contact {
  /// Mensajes recibidos desde el formulario de contacto público.
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String
  subject   String
  message   String
  createdAt DateTime @default(now())
}

model Promotion {
  /// Precio promocional puntual para un paquete turístico.
  id            Int     @id @default(autoincrement())
  tourPackageId Int
  price         Decimal @db.Decimal(10, 2)
  name          String
  description   String
  supplierId    Int
  active        Boolean @default(true)

  reservationDetailPromotions ReservationDetailPromotion[]

  tourPackage TourPackage @relation(fields: [tourPackageId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  supplier    Supplier    @relation(fields: [supplierId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([tourPackageId])
  @@index([supplierId])
  @@index([active])
}

model Offer {
  /// Campaña de descuento que puede aplicarse a uno o varios paquetes.
  id              Int      @id @default(autoincrement())
  name            String   @unique
  description     String?
  discountPercent Float
  startDate       DateTime
  endDate         DateTime
  isGlobal        Boolean  @default(false)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tourPackages OfferTourPackage[]

  @@index([active])
  @@index([startDate, endDate])
}

model OfferTourPackage {
  /// Tabla puente N:N entre ofertas y paquetes turísticos.
  id            Int @id @default(autoincrement())
  offerId       Int
  tourPackageId Int

  offer       Offer       @relation(fields: [offerId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  tourPackage TourPackage @relation(fields: [tourPackageId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([offerId, tourPackageId])
  @@index([tourPackageId])
}

model Reservation {
  /// Cabecera de reserva realizada por un usuario.
  id          Int               @id @default(autoincrement())
  userId      Int
  status      ReservationStatus @default(Pending)
  peopleCount Int
  totalAmount Decimal           @db.Decimal(10, 2)
  code        String            @unique

  user User @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  details ReservationDetail[]
  payment Payment?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model ReservationDetail {
  /// Detalle por paquete incluido dentro de una reserva.
  id            Int @id @default(autoincrement())
  reservationId Int
  tourPackageId Int

  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)
  subtotal  Decimal @db.Decimal(10, 2)

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  tourPackage TourPackage @relation(fields: [tourPackageId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  promotions ReservationDetailPromotion[]

  createdAt DateTime @default(now())

  @@index([reservationId])
  @@index([tourPackageId])
}

model ReservationDetailPromotion {
  /// Promociones efectivamente aplicadas a un detalle de reserva.
  id                  Int     @id @default(autoincrement())
  reservationDetailId Int
  promotionId         Int
  price               Decimal @db.Decimal(10, 2)

  reservationDetail ReservationDetail @relation(fields: [reservationDetailId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  promotion         Promotion         @relation(fields: [promotionId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([reservationDetailId, promotionId])
  @@index([promotionId])
}

model Payment {
  /// Registro transaccional del pago asociado a una reserva.
  id             Int           @id @default(autoincrement())
  reservationId  Int           @unique
  method         PaymentMethod
  status         PaymentStatus @default(Pending)
  amount         Decimal       @db.Decimal(10, 2)
  transactionRef String?
  paidAt         DateTime?

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  createdAt DateTime @default(now())

  @@index([method])
  @@index([status])
  @@index([paidAt])
}

model Department {
  /// Primer nivel geográfico del ubigeo (departamento/región).
  id   Int    @id @default(autoincrement())
  name String @unique

  provinces Province[]
}

model Province {
  /// Segundo nivel geográfico del ubigeo (provincia).
  id           Int    @id @default(autoincrement())
  name         String
  departmentId Int

  department Department @relation(fields: [departmentId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  districts  District[]

  @@unique([name, departmentId])
  @@index([departmentId])
}

model District {
  /// Tercer nivel geográfico del ubigeo (distrito).
  id         Int     @id @default(autoincrement())
  name       String
  ubigeo     String  @unique
  inei       String?
  provinceId Int

  province Province @relation(fields: [provinceId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  tourPackages TourPackage[]

  @@unique([name, provinceId])
  @@index([provinceId])
}
